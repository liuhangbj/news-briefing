def fetch_rss(url, use_proxy=False, timeout=25):
    headers = {'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36'}
    req = urllib.request.Request(url, headers=headers)
    ssl_ctx = ssl.create_default_context()
    ssl_ctx.check_hostname = False
    ssl_ctx.verify_mode = ssl.CERT_NONE
    https_handler = urllib.request.HTTPSHandler(context=ssl_ctx)
    if use_proxy:
        proxy = urllib.request.ProxyHandler({'http': MIHOMO_PROXY, 'https': MIHOMO_PROXY})
        opener = urllib.request.build_opener(proxy, https_handler)
    else:
        opener = urllib.request.build_opener(https_handler)
    try:
        with opener.open(req, timeout=timeout) as resp:
            html = resp.read()
        root = ET.fromstring(html)
        tag = root.tag
        if tag.endswith('feed'):
            return parse_atom(root)
        else:
            return parse_rss(root)
    except Exception as e:
        log(f"RSS失败 [{url[:50]}]: {e}")
        return []

def parse_rss(root):
    items = []
    # 标准 RSS 2.0
    for item in root.iter('item'):
        title = item.findtext('title', '')
        link = item.findtext('link', '')
        desc = ''
        for child in item:
            if child.tag.endswith('encoded'):
                desc = child.text or ''
                break
        if not desc:
            desc = item.findtext('description', '')
        pub_date = item.findtext('pubDate', item.findtext('dc:date', ''))
        if not title:
            continue
        items.append({
            'title': clean_html(title),
            'url': link.strip() if link else '',
            'desc': clean_html(desc)[:800],
            'pub_date': pub_date or '',
        })
    
    # RDF 格式 (RSS 1.0, 如 DW 中文)
    if not items:
        rdf_ns = 'http://purl.org/rss/1.0/'
        # ElementTree 使用 Clark 记法: {namespace}tagname
        for item in root.iter(f'{{{rdf_ns}}}item'):
            title = item.findtext(f'{{{rdf_ns}}}title', '')
            link = item.findtext(f'{{{rdf_ns}}}link', '')
            desc = item.findtext(f'{{{rdf_ns}}}description', '')
            # 尝试 dc:date
            pub_date = ''
            for child in item:
                if 'date' in child.tag:
                    pub_date = child.text or ''
                    break
            if not title:
                continue
            items.append({
                'title': clean_html(title),
                'url': link.strip() if link else '',
                'desc': clean_html(desc)[:800],
                'pub_date': pub_date or '',
            })
    
    return items

def parse_atom(root):
    ns = {'atom': 'http://www.w3.org/2005/Atom'}
    entries = list(root.iter('{http://www.w3.org/2005/Atom}entry'))
    if not entries:
        entries = list(root.iter('entry'))
    items = []
    for entry in entries:
        title_elem = entry.find('atom:title', ns) or entry.find('title')
        title = title_elem.text if title_elem is not None else ''
        link = ''
        link_elem = entry.find('atom:link', ns) or entry.find('link')
        if link_elem is not None:
            link = link_elem.get('href', '')
        content = ''
        content_elem = entry.find('atom:content', ns) or entry.find('content')
        if content_elem is not None and content_elem.text:
            content = content_elem.text
        if not content:
            summary_elem = entry.find('atom:summary', ns) or entry.find('summary')
            if summary_elem is not None:
                content = summary_elem.text or ''
        updated_elem = entry.find('atom:updated', ns) or entry.find('updated')
        pub_date = updated_elem.text if updated_elem is not None else ''
        if not title:
            continue
        items.append({
            'title': clean_html(title),
            'url': link.strip() if link else '',
            'desc': clean_html(content)[:800],
            'pub_date': pub_date or '',
        })
    return items

def fetch_hotnews(platform, max_items=5, use_proxy=True):
    url = f"{HOTNEWS_API}/?platform={platform}"
    try:
        headers = {'User-Agent': 'Mozilla/5.0'}
        req = urllib.request.Request(url, headers=headers)
        ssl_ctx = ssl.create_default_context()
        ssl_ctx.check_hostname = False
        ssl_ctx.verify_mode = ssl.CERT_NONE
        # 构建带重定向支持的 opener
        proxy = urllib.request.ProxyHandler({'http': MIHOMO_PROXY, 'https': MIHOMO_PROXY}) if use_proxy else urllib.request.ProxyHandler({})
        https = urllib.request.HTTPSHandler(context=ssl_ctx)
        # 自定义重定向处理器，保留 headers
        class CustomRedirectHandler(urllib.request.HTTPRedirectHandler):
            def redirect_request(self, req, fp, code, msg, headers, newurl):
                newreq = urllib.request.HTTPRedirectHandler.redirect_request(self, req, fp, code, msg, headers, newurl)
                if newreq and req.headers:
                    newreq.headers = req.headers
                return newreq
        opener = urllib.request.build_opener(proxy, https, CustomRedirectHandler())
        with opener.open(req, timeout=20) as resp:
            data = json.loads(resp.read().decode('utf-8'))
        items = data.get('data', [])
        results = []
        for item in items[:max_items]:
            title = item.get('title', '').strip()
            url = item.get('url', '').strip()
            score = item.get('score', '')
            if not title or not url:
                continue
            score_str = format_score(score) if score else ''
            desc = f"热度 {score_str}" if score_str else ''
            results.append({
                'title': title,
                'url': url,
                'desc': desc,
                'pub_date': '',
            })
        return results
    except Exception as e:
        log(f"hot_news失败 [{platform}]: {e}")
        return []

