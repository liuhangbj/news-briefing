    yesterday_8am = today_8am - timedelta(days=1)
    
    log(f"[时间窗口] {yesterday_8am.strftime('%Y-%m-%d %H:%M')} ~ {today_8am.strftime('%Y-%m-%d %H:%M')}")
    
