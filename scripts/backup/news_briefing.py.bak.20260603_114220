def push_to_github(content, filename):
    """推送文件到 GitHub 仓库,返回 GitHub Pages URL"""
    if not GITHUB_TOKEN:
        log("GITHUB_TOKEN 未设置,跳过 GitHub 推送")
        return None

    import base64
    encoded = base64.b64encode(content.encode('utf-8')).decode('utf-8')

    url = f"https://api.github.com/repos/{GITHUB_USER}/{GITHUB_REPO}/contents/{filename}"

    # 先检查文件是否已存在(获取 sha)
    sha = None
    try:
        req_get = urllib.request.Request(
            url,
            headers={
                'Authorization': f'token {GITHUB_TOKEN}',
                'Accept': 'application/vnd.github.v3+json',
            }
        )
        with urllib.request.urlopen(req_get, timeout=10) as resp:
            existing = json.loads(resp.read().decode('utf-8'))
            sha = existing.get('sha')
    except:
        pass  # 文件不存在

    # 创建或更新文件
    payload = {
        'message': f'News briefing {filename}',
        'content': encoded,
        'branch': GITHUB_BRANCH,
    }
    if sha:
        payload['sha'] = sha

    try:
        req_put = urllib.request.Request(
            url,
            data=json.dumps(payload).encode('utf-8'),
            headers={
                'Authorization': f'token {GITHUB_TOKEN}',
                'Accept': 'application/vnd.github.v3+json',
                'Content-Type': 'application/json',
            },
            method='PUT',
        )
        with urllib.request.urlopen(req_put, timeout=15) as resp:
            result = json.loads(resp.read().decode('utf-8'))
            # 返回 GitHub Pages URL(Cubox 能正确解析)
            pages_url = f"https://{GITHUB_USER}.github.io/{GITHUB_REPO}/{filename}"
            log(f"GitHub 推送成功: {pages_url}")
            return pages_url
    except Exception as e:
        log(f"GitHub 推送失败: {e}")
        return None

