def dedup_by_topic(articles):
    """按话题相似度去重,保留第一条"""
    unique = []
    skipped = 0
    for a in articles:
        title = a.get('title', '')
        is_dup = False
        for u in unique:
            if is_similar_topic(title, u.get('title', '')):
                is_dup = True
                break
        if is_dup:
            skipped += 1
        else:
            unique.append(a)
    if skipped > 0:
        log(f"话题级去重: 跳过 {skipped} 条相似文章")
    return unique

