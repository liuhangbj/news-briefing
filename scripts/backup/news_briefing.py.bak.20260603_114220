def _call_llm_for_keep(prompt, expected_count):
    """
    调用LLM API,返回 {index: (1/0, reason)}
    支持 OpenAI 兼容和 Anthropic 兼容(Kimi Coding)两种协议
    """
    # 判断协议类型
    is_anthropic = 'kimi.com/coding' in LLM_BASE_URL
    
    if is_anthropic:
        # Anthropic 兼容协议 (Kimi Coding)
        req_data = json.dumps({
            "model": LLM_MODEL,
            "messages": [{"role": "user", "content": prompt}],
            "max_tokens": 2000,
            "temperature": 0.1,
        }).encode('utf-8')
        req = urllib.request.Request(
            f"{LLM_BASE_URL}/messages",
            data=req_data,
            headers={
                'x-api-key': LLM_API_KEY,
                'anthropic-version': '2023-06-01',
                'Content-Type': 'application/json',
            },
            method='POST'
        )
    else:
        # OpenAI 兼容协议
        req_data = json.dumps({
            "model": LLM_MODEL,
            "messages": [{"role": "user", "content": prompt}],
            "max_tokens": 2000,
            "temperature": 0.1,
        }).encode('utf-8')
        req = urllib.request.Request(
            f"{LLM_BASE_URL}/chat/completions",
            data=req_data,
            headers={
                'Authorization': f'Bearer {LLM_API_KEY}',
                'Content-Type': 'application/json',
            },
            method='POST'
        )
    
    ssl_ctx = ssl.create_default_context()
    ssl_ctx.check_hostname = False
    ssl_ctx.verify_mode = ssl.CERT_NONE
    try:
        with urllib.request.urlopen(req, context=ssl_ctx, timeout=120) as resp:
            result = json.loads(resp.read().decode('utf-8'))
    except urllib.error.HTTPError as e:
        error_body = e.read().decode('utf-8', errors='replace')
        log(f"[LLM取舍] API HTTP {e.code}: {e.reason}")
        log(f"[LLM取舍] Error body: {error_body[:300]}")
        raise
    
    # 解析响应
    if 'content' in result and isinstance(result['content'], list):
        # Anthropic 格式
        content = result['content'][0].get('text', '') if result['content'] else ''
    elif 'choices' in result:
        # OpenAI 格式
        content = result['choices'][0]['message']['content']
    else:
        content = str(result)
    return _parse_llm_keep(content, expected_count)

def _parse_llm_keep(content, expected_count):
    """解析LLM返回的保留/丢弃判断"""
    results = {}
    for line in content.strip().split('\n'):
        line = line.strip()
        if not line:
            continue
        m = re.match(r'^\s*(\d+)[.\s]+(保留|丢弃)[\s::]+(.+)$', line)
        if not m:
            m = re.match(r'^\s*(\d+)[.\s]*(保留|丢弃)[\s::]*(.+)$', line)
        if m:
            idx = int(m.group(1)) - 1
            action = m.group(2)
            reason = m.group(3).strip()
            keep = 1 if action == '保留' else 0
            if 0 <= idx < expected_count:
                results[idx] = (keep, reason)
    for i in range(expected_count):
        if i not in results:
            results[i] = (1, '未解析默认保留')
    return results

