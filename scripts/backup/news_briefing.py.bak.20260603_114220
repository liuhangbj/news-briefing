def translate_and_summarize(items):
    if not LLM_API_KEY:
        log("警告: LLM API Key未设置,跳过翻译")
        return items
    if not items:
        return items
    lines = ["请将以下文章翻译成中文并生成一句话摘要。\n"]
    for i, item in enumerate(items, 1):
        title = item['title'].replace('\n', ' ')
        desc = item['desc'].replace('\n', ' ')[:400]
        lines.append(f"{i}. 标题: {title}")
        lines.append(f"   描述: {desc}")
        lines.append("")
    lines.append("输出要求:")
    lines.append("- 标题:翻译成简洁的中文标题")
    lines.append("- 摘要:一句话概括核心内容,不超过50字")
    lines.append("- 如果标题已经是中文,保留原样")
    lines.append("- 只输出纯文本,每篇文章占两行:")
    lines.append("  标题: xxx")
    lines.append("  摘要: xxx")
    lines.append("")
    prompt = '\n'.join(lines)
    try:
        req_data = json.dumps({
            "model": LLM_MODEL,
            "messages": [{"role": "user", "content": prompt}],
            "max_tokens": 2000,
        }).encode('utf-8')
        req = urllib.request.Request(
            f"{LLM_BASE_URL}/messages",
            data=req_data,
            headers={
                'Authorization': f'Bearer {LLM_API_KEY}',
                'Content-Type': 'application/json',
            },
            method='POST'
        )
        ssl_ctx = ssl.create_default_context()
        ssl_ctx.check_hostname = False
        ssl_ctx.verify_mode = ssl.CERT_NONE
        with urllib.request.urlopen(req, context=ssl_ctx, timeout=60) as resp:
            result = json.loads(resp.read().decode('utf-8'))
        if 'content' in result and len(result['content']) > 0:
            content = result['content'][0].get('text', '')
        elif 'choices' in result:
            content = result['choices'][0]['message']['content']
        else:
            content = str(result)
        parsed = parse_llm_output(content, len(items))
        for i, (new_title, new_summary) in enumerate(parsed):
            if i < len(items):
                if new_title:
                    items[i]['title'] = new_title
                if new_summary:
                    items[i]['desc'] = new_summary
        log(f"LLM翻译完成: {len([p for p in parsed if p[0]])}/{len(items)}条")
        return items
    except Exception as e:
        log(f"LLM翻译失败: {e}")
        for item in items:
            if item['desc']:
                item['desc'] = item['desc'][:100] + '...' if len(item['desc']) > 100 else item['desc']
        return items

def parse_llm_output(content, expected_count):
    results = []
    lines = content.strip().split('\n')
    current_title = None
    current_summary = None
    for line in lines:
        line = line.strip()
        if not line:
            continue
        title_match = re.match(r'^(?:\d+[.、]\s*)?[标題]?标题[::]\s*(.+)', line)
        if title_match:
            if current_title or current_summary:
                results.append((current_title or '', current_summary or ''))
            current_title = title_match.group(1).strip()
            current_summary = None
            continue
        summary_match = re.match(r'^(?:\d+[.、]\s*)?摘要[::]\s*(.+)', line)
        if summary_match:
            current_summary = summary_match.group(1).strip()
            continue
    if current_title or current_summary:
        results.append((current_title or '', current_summary or ''))
    if len(results) < expected_count // 2:
        results = []
        blocks = content.strip().split('\n\n')
        for block in blocks:
            lines_in_block = [l.strip() for l in block.split('\n') if l.strip()]
            t, s = '', ''
            for l in lines_in_block:
                if '标题' in l or 'title' in l.lower():
                    t = re.sub(r'.*标题[::]\s*', '', l).strip()
                elif '摘要' in l or 'summary' in l.lower():
                    s = re.sub(r'.*摘要[::]\s*', '', l).strip()
            if t or s:
                results.append((t, s))
    while len(results) < expected_count:
        results.append(('', ''))
    return results[:expected_count]

