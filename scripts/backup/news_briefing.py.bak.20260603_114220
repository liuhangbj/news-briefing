def is_english_text(text, threshold=0.3):
    """检测文本是否含大量英文(需要翻译)"""
    if not text:
        return False
    text = text.strip()
    if not text:
        return False
    # 统计英文字符比例
    ascii_chars = sum(1 for c in text if ord(c) < 128 and c.isalpha())
    total_chars = len(text.replace(' ', '').replace('\n', ''))
    if total_chars == 0:
        return False
    return ascii_chars / total_chars > threshold

def should_include(title, category):
    """判断文章是否应该被包含在简报中"""
    t = title.lower()

    # 排除列表/汇总类
    if any(w.lower() in t for w in TITLE_DENY_PATTERNS['aggregate']):
        return False

    # 排除非新闻事件类
    if any(w.lower() in t for w in TITLE_DENY_PATTERNS['non_news']):
        return False

    # 财经分类排除个股类
    if category == '财经':
        if any(w.lower() in t for w in TITLE_DENY_PATTERNS['stock']):
            return False
        if has_stock_code(title):
            return False

    return True

