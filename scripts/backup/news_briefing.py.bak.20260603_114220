def llm_score_articles(articles):
    """
    v3.2: LLM 取舍判断
    只给已命中关键词的文章判断,返回 [(1/0, reason), ...]
    1=保留, 0=丢弃
    批量处理,每批最多10条
    """
    if not LLM_API_KEY or not articles:
        return [(0, '') for _ in articles]

    to_score = []
    to_score_indices = []
    results = []

    for i, a in enumerate(articles):
        if a.get('score', 0) > 0:
            to_score.append(a)
            to_score_indices.append(i)
            results.append((0, 'pending'))
        else:
            results.append((0, '关键词未命中'))

    if not to_score:
        return results

    batch_size = 10
    total_batches = (len(to_score) + batch_size - 1) // batch_size
    log(f"[LLM取舍] {len(to_score)}篇候选,分{total_batches}批(每批{batch_size}条)")

    for batch_idx in range(total_batches):
        start = batch_idx * batch_size
        end = min(start + batch_size, len(to_score))
        batch = to_score[start:end]
        batch_indices = to_score_indices[start:end]

        prompt = _build_keep_prompt(batch)

        # 批次间延迟,避免 API 速率限制
        if batch_idx > 0:
            time.sleep(2)

        max_retries = 3
        for attempt in range(max_retries):
            try:
                keep_map = _call_llm_for_keep(prompt, len(batch))
                for i, idx in enumerate(batch_indices):
                    keep, reason = keep_map.get(i, (1, '解析失败默认保留'))
                    results[idx] = (keep, reason)
                log(f"[LLM取舍] 批次{batch_idx+1}/{total_batches}完成")
                break
            except urllib.error.HTTPError as e:
                error_body = e.read().decode('utf-8', errors='replace')
                is_high_risk = 'high risk' in error_body.lower()
                if is_high_risk and len(batch) > 1:
                    # high risk 批次拆分为单条，逐条用 Kimi 重试
                    log(f"[LLM取舍] 批次{batch_idx+1}/{total_batches} high risk,拆分为单条重试")
                    for sub_i, (article, orig_idx) in enumerate(zip(batch, batch_indices)):
                        sub_prompt = _build_keep_prompt([article])
                        time.sleep(1)
                        sub_success = False
                        for sub_attempt in range(2):
                            try:
                                keep_map = _call_llm_for_keep(sub_prompt, 1)
                                keep, reason = keep_map.get(0, (1, '解析失败默认保留'))
                                results[orig_idx] = (keep, reason)
                                sub_success = True
                                break
                            except urllib.error.HTTPError as sub_e:
                                sub_body = sub_e.read().decode('utf-8', errors='replace')
                                if 'high risk' in sub_body.lower():
                                    log(f"[LLM取舍] 单条high risk,默认保留: {article['title'][:30]}...")
                                    results[orig_idx] = (1, 'high risk单条过滤默认保留')
                                    sub_success = True
                                    break
                                if sub_attempt < 1:
                                    time.sleep(2)
                        if not sub_success:
                            results[orig_idx] = (1, 'LLM单条失败默认保留')
                    log(f"[LLM取舍] 批次{batch_idx+1}/{total_batches}拆分完成")
                    break
                else:
                    log(f"[LLM取舍] 批次{batch_idx+1}/{total_batches} 尝试{attempt+1}/{max_retries}失败: {e}")
                    log(f"[LLM取舍] Error body: {error_body[:200]}")
                    if attempt < max_retries - 1:
                        wait = 3 * (2 ** attempt)
                        log(f"[LLM取舍] 等待{wait}秒后重试...")
                        time.sleep(wait)
                        continue
                    for idx in batch_indices:
                        results[idx] = (1, f'LLM失败({max_retries}次重试后)默认保留')
            except Exception as e:
                log(f"[LLM取舍] 批次{batch_idx+1}/{total_batches} 尝试{attempt+1}/{max_retries}失败: {e}")
                if attempt < max_retries - 1:
                    wait = 3 * (2 ** attempt)
                    log(f"[LLM取舍] 等待{wait}秒后重试...")
                    time.sleep(wait)
                    continue
                for idx in batch_indices:
                    results[idx] = (1, f'LLM失败({max_retries}次重试后)默认保留')

    return results


def _build_topic_prompt(articles):
    """构建热门话题聚类 prompt"""
    lines = [
        "基于以下当天新闻，识别3-8个热门话题。",
        "重要规则：每个话题必须至少关联2条新闻，只有1条新闻的主题不单独列为话题。",
        "每个话题需要：",
        "1. 话题标题（简洁，10字以内）",
        "2. 话题综述（基于当天所有相关新闻，对当天最新进展做综合综述，不是背景介绍，100-150字）",
        "3. 相关文章编号（从新闻列表中选最相关的，至少2条、最多8条）",
        "",
        "输出格式：",
        "话题N: 标题",
        "综述: ...",
        "相关: 1,3,5",
        "",
        "新闻列表:"
    ]
    for idx, a in enumerate(articles, 1):
        source = a.get('source', '未知')
        title = a.get('title', '')[:60]
        desc = (a.get('desc', '') or '')[:40]
        lines.append(f"{idx}. [{source}] {title}")
        if desc:
            lines.append(f"   {desc}")
    return '\n'.join(lines)

def _call_llm_for_topics(prompt):
    """调用LLM进行话题聚类，返回 [(topic_title, summary, [article_indices]), ...]"""
    is_anthropic = 'kimi.com/coding' in LLM_BASE_URL
    
    if is_anthropic:
        req_data = json.dumps({
            "model": LLM_MODEL,
            "messages": [{"role": "user", "content": prompt}],
            "max_tokens": 4000,
            "temperature": 0.3,
        }).encode('utf-8')
        req = urllib.request.Request(
            f"{LLM_BASE_URL}/messages",
            data=req_data,
            headers={
                'x-api-key': LLM_API_KEY,
                'anthropic-version': '2023-06-01',
                'Content-Type': 'application/json',
            },
            method='POST'
        )
    else:
        req_data = json.dumps({
            "model": LLM_MODEL,
            "messages": [{"role": "user", "content": prompt}],
            "max_tokens": 4000,
            "temperature": 0.3,
        }).encode('utf-8')
        req = urllib.request.Request(
            f"{LLM_BASE_URL}/chat/completions",
            data=req_data,
            headers={
                'Authorization': f'Bearer {LLM_API_KEY}',
                'Content-Type': 'application/json',
            },
            method='POST'
        )
    
    ssl_ctx = ssl.create_default_context()
    ssl_ctx.check_hostname = False
    ssl_ctx.verify_mode = ssl.CERT_NONE
    try:
        with urllib.request.urlopen(req, context=ssl_ctx, timeout=180) as resp:
            result = json.loads(resp.read().decode('utf-8'))
    except urllib.error.HTTPError as e:
        error_body = e.read().decode('utf-8', errors='replace')
        log(f"[热门话题] API HTTP {e.code}: {e.reason}")
        raise
    
    if 'content' in result and isinstance(result['content'], list):
        content = result['content'][0].get('text', '') if result['content'] else ''
    elif 'choices' in result:
        content = result['choices'][0]['message']['content']
    else:
        content = str(result)
    return _parse_llm_topics(content)

def _parse_llm_topics(content):
    """解析LLM返回的话题列表"""
    topics = []
    current = None
    
    for line in content.strip().split('\n'):
        line = line.strip()
        if not line:
            continue
        
        # 话题标题行: "话题1: xxx" 或 "1. xxx"
        m = re.match(r'(?:话题\s*\d+[:\.]\s*|\d+[:\.]\s*)(.+)', line)
        if m:
            if current:
                topics.append(current)
            current = {'title': m.group(1).strip(), 'summary': '', 'indices': []}
            continue
        
    # 综述行
    summary = ''
    for line in lines[1:]:
        line = line.strip()
        if not line:
            continue
        m = re.match(r'综述[:\s]+(.+)', line, re.IGNORECASE)
        if m:
            summary = m.group(1).strip()
            break
        # 如果没有明确标记，第二行作为综述
        if not summary and len(line) > 20:
            summary = line
    
    current['summary'] = summary
    
    # 提取相关文章索引
    indices = []
    for line in lines:
        nums = re.findall(r'\d+', line)
        if nums:
            indices.extend([int(n)-1 for n in nums])
    current['indices'] = list(set(indices))[:20]  # 去重，最多20条
    
    if current['title'] and current['indices']:
        topics.append(current)
    
    return topics


