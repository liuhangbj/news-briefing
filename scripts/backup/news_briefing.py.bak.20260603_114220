def has_stock_code(title):
    """检测标题中是否包含股票代码"""
    # 匹配 6位数字.SZ / .SH / .BJ
    if re.search(r'\d{6}\.(SZ|SH|BJ)', title):
        return True
    # 匹配括号内的股票代码 (XXXXXX)
    if re.search(r'\(\d{6}\)', title):
        return True
    # 匹配 30xxxx / 00xxxx / 60xxxx / 68xxxx
    if re.search(r'\b(30|00|60|68|83|87)\d{4}\b', title):
        return True
    return False



def score_article(title, source_name, desc=''):
    """词组匹配打分:命中词组加分,排除词直接丢弃"""
    text = (title or '') + ' ' + (desc or '')

    # 1. 全局过滤检查
    for filter_word in GLOBAL_FILTER:
        if filter_word in text:
            return -999, '过滤', ['全局过滤:' + filter_word]

    score = 0
    matched_category = None
    matched_groups = []

    for group in KEYWORD_GROUPS:
        # 检查排除词
        excluded = False
        for ex in group.get('exclude', []):
            if ex in text:
                excluded = True
                break
        if excluded:
            continue

        # 检查触发词(命中任意一个)
        keyword_hit = False
        for kw in group.get('keywords', []):
            if kw in text:
                keyword_hit = True
                break

        if not keyword_hit:
            continue

        # 检查必须词(如果配置了必须词,必须命中至少一个)
        required_list = group.get('required', [])
        if required_list:
            required_hit = False
            for req in required_list:
                if req in text:
                    required_hit = True
                    break
            if not required_hit:
                continue

        # 命中词组,加分
        bonus = group.get('bonus', 1)
        score += bonus
        matched_groups.append(group['name'])
        if matched_category is None:
            matched_category = group['category']

    return score, matched_category, matched_groups


