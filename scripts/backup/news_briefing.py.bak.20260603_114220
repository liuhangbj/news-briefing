def _render_article(lines, item):
    """渲染单篇文章到HTML（供最终简报使用）"""
    title = item['title']
    # 去掉源前缀如 [1.快讯]、[联合早报] 等
    title = re.sub(r'^\[.*?\]\s*', '', title)
    desc = item['desc']
    url = item['url']
    source = item.get('source', '')
    k_score = item.get('score', 0)
    l_score = item.get('llm_score', 0)
    total_score = k_score + l_score
    is_high = total_score >= 5
    
    css_class = 'high' if is_high else ''
    lines.append(f'  <article class="{css_class}">')
    score_tag = f' <span class="article-score">[{k_score}+{l_score}={total_score}]</span>' if is_high else ''
    if url:
        lines.append(f'    <h2><a href="{url}" target="_blank">{title}</a>{score_tag}</h2>')
    else:
        lines.append(f'    <h2>{title}{score_tag}</h2>')
    if desc and desc.strip():
        lines.append(f'    <p>{desc}</p>')
    if source:
        lines.append(f'    <p class="source">来源: {source}</p>')
    lines.append('  </article>')
    lines.append('')

